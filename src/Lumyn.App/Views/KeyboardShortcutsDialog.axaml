<Window
    x:Class="Lumyn.App.Views.KeyboardShortcutsDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Keyboard Shortcuts"
    Width="500"
    Height="560"
    MinWidth="420"
    MinHeight="400"
    CanResize="True"
    WindowStartupLocation="CenterOwner"
    Background="#1E1E1E">

  <Grid RowDefinitions="*,Auto" Margin="20,16,20,16">

    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="0">

        <!-- Playback -->
        <TextBlock Text="PLAYBACK"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#807C79" Margin="0,0,0,8" />
        <Grid Name="PlaybackGroup" />

        <!-- Seeking -->
        <TextBlock Text="SEEKING"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#807C79" Margin="0,16,0,8" />
        <Grid Name="SeekingGroup" />

        <!-- Volume -->
        <TextBlock Text="VOLUME"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#807C79" Margin="0,16,0,8" />
        <Grid Name="VolumeGroup" />

        <!-- Speed -->
        <TextBlock Text="SPEED"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#807C79" Margin="0,16,0,8" />
        <Grid Name="SpeedGroup" />

        <!-- Tracks -->
        <TextBlock Text="TRACKS"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#807C79" Margin="0,16,0,8" />
        <Grid Name="TracksGroup" />

        <!-- Window -->
        <TextBlock Text="WINDOW"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#807C79" Margin="0,16,0,8" />
        <Grid Name="WindowGroup" />

        <!-- File / dialogs -->
        <TextBlock Text="FILE &amp; DIALOGS"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#807C79" Margin="0,16,0,8" />
        <Grid Name="FileGroup" />

      </StackPanel>
    </ScrollViewer>

    <!-- Close button -->
    <Border Grid.Row="1" BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="-20,8,-20,-16">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,10,20,0">
        <Button Name="CloseBtn" Content="Close" Classes="accent" Click="CloseBtn_Click" />
      </StackPanel>
    </Border>

  </Grid>
</Window>
