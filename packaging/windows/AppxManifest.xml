<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10">

  <Identity
    Name="PiyushDoorwar.Lumyn"
    Publisher="CN=Piyush Doorwar, O=Piyush Doorwar, C=US"
    Version="0.0.0.0" />

  <Properties>
    <DisplayName>Lumyn</DisplayName>
    <PublisherDisplayName>Piyush Doorwar</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.14393.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application
      Id="App"
      StartPage="Lumyn.exe">
      <uap:VisualElements
        DisplayName="Lumyn"
        Square150x150Logo="Assets\square150x150logo.png"
        Square44x44Logo="Assets\square44x44logo.png"
        Description="A powerful and minimal media player"
        BackgroundColor="transparent">
        <uap:DefaultTile
          Wide310x150Logo="Assets\wide310x150logo.png"
          Square310x310Logo="Assets\square310x310logo.png"
          ShortName="Lumyn" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>
      <Extensions>
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="video">
            <uap:SupportedFileTypes>
              <uap:FileType>.mp4</uap:FileType>
              <uap:FileType>.m4v</uap:FileType>
              <uap:FileType>.mkv</uap:FileType>
              <uap:FileType>.mk3d</uap:FileType>
              <uap:FileType>.webm</uap:FileType>
              <uap:FileType>.avi</uap:FileType>
              <uap:FileType>.mov</uap:FileType>
              <uap:FileType>.mpg</uap:FileType>
              <uap:FileType>.mpeg</uap:FileType>
              <uap:FileType>.flv</uap:FileType>
              <uap:FileType>.3gp</uap:FileType>
              <uap:FileType>.wmv</uap:FileType>
              <uap:FileType>.ogv</uap:FileType>
              <uap:FileType>.ogm</uap:FileType>
              <uap:FileType>.ts</uap:FileType>
              <uap:FileType>.divx</uap:FileType>
            </uap:SupportedFileTypes>
          </uap:FileTypeAssociation>
        </uap:Extension>
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="audio">
            <uap:SupportedFileTypes>
              <uap:FileType>.mp3</uap:FileType>
              <uap:FileType>.flac</uap:FileType>
              <uap:FileType>.ogg</uap:FileType>
              <uap:FileType>.oga</uap:FileType>
              <uap:FileType>.wav</uap:FileType>
              <uap:FileType>.m4a</uap:FileType>
              <uap:FileType>.aac</uap:FileType>
              <uap:FileType>.wma</uap:FileType>
              <uap:FileType>.opus</uap:FileType>
              <uap:FileType>.mka</uap:FileType>
            </uap:SupportedFileTypes>
          </uap:FileTypeAssociation>
        </uap:Extension>
      </Extensions>
    </Application>
  </Applications>

</Package>
