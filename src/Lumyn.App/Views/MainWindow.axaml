<Window
    x:Class="Lumyn.App.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Lumyn.App.Controls"
    Title="{Binding Title}"
    Width="980"
    Height="620"
    MinWidth="640"
    MinHeight="380"
    Background="#111111"
    Topmost="{Binding IsAlwaysOnTop}"
    ExtendClientAreaToDecorationsHint="False">

  <!--
    All layers stacked in a Panel. mpv renders video into an OpenGL surface
    at the bottom; Avalonia controls remain normal overlays above it.
  -->
  <Panel Name="Root" Background="#111111" DragDrop.AllowDrop="True">

    <!-- ── Video frame (mpv OpenGL render API) ──────────────────────────── -->
    <controls:MpvVideoSurface Name="VideoSurface"
           Playback="{Binding Playback}"
           HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
           IsHitTestVisible="False" />

    <!-- ── Transparent click / double-click surface ───────────────────────── -->
    <Border Name="VideoClickLayer" Background="Transparent"
            PointerPressed="VideoClickLayer_OnPointerPressed" />

    <!-- ── Subtitle overlay (Avalonia-rendered; VLC SPU is disabled) ───────── -->
    <Border VerticalAlignment="Bottom"
            HorizontalAlignment="Stretch"
            Margin="24,0,24,72"
            IsHitTestVisible="False"
            IsVisible="{Binding CurrentSubtitleText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="{Binding CurrentSubtitleText}"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 FontSize="22"
                 FontWeight="SemiBold"
                 Foreground="White"
                 TextWrapping="Wrap"
                 MaxWidth="900">
        <TextBlock.Effect>
          <DropShadowEffect BlurRadius="4" OffsetX="1" OffsetY="1" Color="Black" Opacity="0.9" />
        </TextBlock.Effect>
      </TextBlock>
    </Border>

    <!-- ── Empty-state placeholder ───────────────────────────────────────── -->
    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Spacing="12"
        IsVisible="{Binding !HasMedia}"
        IsHitTestVisible="False">
      <Image Width="120" Height="120" Opacity="0.85" Source="{StaticResource Icon.LumynLogo}" />
      <TextBlock Text="Lumyn" FontSize="28" FontWeight="SemiBold"
                 Foreground="#F7F5F3" HorizontalAlignment="Center" />
      <TextBlock Text="Drop a file here, press O to open, or right-click"
                 FontSize="13" Foreground="#807C79" HorizontalAlignment="Center" />
    </StackPanel>

    <!-- ── Error banner ──────────────────────────────────────────────────── -->
    <Border
        VerticalAlignment="Top"
        Margin="0,48,0,0"
        IsVisible="{Binding HasError}"
        Padding="16,8"
        Background="#CC77216F"
        IsHitTestVisible="False">
      <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFFFFF"
                 TextWrapping="Wrap" HorizontalAlignment="Center" />
    </Border>

    <!-- ── OSD overlay ───────────────────────────────────────────────────── -->
    <Border
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Margin="0,-80,0,0"
        Padding="22,10"
        CornerRadius="8"
        Background="#CC000000"
        IsVisible="{Binding HasOsd}"
        IsHitTestVisible="False">
      <TextBlock Text="{Binding OsdMessage}" FontSize="17" FontWeight="SemiBold"
                 Foreground="#F7F5F3" />
    </Border>

    <!-- ── Top bar overlay ───────────────────────────────────────────────── -->
    <Border
        Name="TopBar"
        VerticalAlignment="Top"
        Padding="10,6,10,20"
        Opacity="{Binding ControlsOpacity}"
        IsHitTestVisible="{Binding ControlsVisible}">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#BB000000" Offset="0" />
          <GradientStop Color="#00000000" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="4">
        <Image Grid.Column="0" Width="22" Height="22" Margin="2,0,8,0"
               Source="{StaticResource Icon.LumynMark}" />
        <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center"
                   FontSize="13" Foreground="#DEDAD5" TextTrimming="CharacterEllipsis" />
        <Button Grid.Column="2" Classes="icon" Name="OpenButton"
                Click="OpenButton_OnClick">
          <PathIcon Width="17" Height="17" Data="{StaticResource Icon.Open}" />
        </Button>
        <Button Grid.Column="3" Classes="icon" Name="LoadSubtitleButton"
                Click="LoadSubtitleButton_OnClick">
          <PathIcon Width="17" Height="17" Data="{StaticResource Icon.Subtitle}" />
        </Button>
        <Button Grid.Column="4" Classes="icon ctrl" Name="AlwaysOnTopButton"
                Classes.dim="{Binding !IsAlwaysOnTop}"
                Command="{Binding ToggleAlwaysOnTopCommand}">
          <PathIcon Width="15" Height="15" Data="{StaticResource Icon.AlwaysOnTop}" />
        </Button>
        <Button Grid.Column="5" Classes="icon" Name="FullscreenButton"
                Click="FullscreenButton_OnClick">
          <PathIcon Name="FullscreenIcon" Width="17" Height="17"
                    Data="{StaticResource Icon.Fullscreen}" />
        </Button>
      </Grid>
    </Border>

    <!-- ── Bottom control bar overlay ────────────────────────────────────── -->
    <Border
        Name="ControlBar"
        VerticalAlignment="Bottom"
        Padding="12,0,12,10"
        Opacity="{Binding ControlsOpacity}"
        IsHitTestVisible="{Binding ControlsVisible}">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#00000000" Offset="0" />
          <GradientStop Color="#D5000000" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
      <StackPanel Spacing="0">

        <!-- Seek slider -->
        <controls:SeekBar
            Name="SeekSlider"
            Minimum="0"
            Maximum="1000"
            Value="{Binding SeekValue}"
            Margin="0,0,0,2"
            SeekCommitted="SeekSlider_OnSeekCommitted" />

        <!-- Transport row -->
        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto"
              ColumnSpacing="2" Margin="2,0">

          <!-- Play / Pause -->
          <Button Grid.Column="0" Classes="ctrl"
                  Command="{Binding TogglePlayPauseCommand}">
            <Panel>
              <PathIcon Width="18" Height="18" Data="{StaticResource Icon.Play}"
                        IsVisible="{Binding !IsPlaying}" />
              <PathIcon Width="18" Height="18" Data="{StaticResource Icon.Pause}"
                        IsVisible="{Binding IsPlaying}" />
            </Panel>
          </Button>

          <!-- Stop -->
          <Button Grid.Column="1" Classes="ctrl"
                  Command="{Binding StopCommand}">
            <PathIcon Width="14" Height="14" Data="{StaticResource Icon.Stop}" />
          </Button>

          <!-- Time display -->
          <TextBlock Grid.Column="2" Text="{Binding TimeText}"
                     VerticalAlignment="Center" FontSize="12"
                     Foreground="#C8C3C2" Margin="6,0" />

          <!-- Spacer -->
          <Border Grid.Column="3" />

          <!-- Speed badge -->
          <Button Grid.Column="4" Classes="ctrl"
                  Command="{Binding ResetSpeedCommand}">
            <TextBlock Text="{Binding SpeedLabel}" FontSize="11" Foreground="#C8C3C2"
                       VerticalAlignment="Center" />
          </Button>

          <!-- Loop -->
          <Button Grid.Column="5" Classes="ctrl"
                  Classes.dim="{Binding !IsLooping}"
                  Command="{Binding ToggleLoopCommand}">
            <PathIcon Width="16" Height="16" Data="{StaticResource Icon.Loop}" />
          </Button>

          <!-- Mute / Unmute -->
          <Button Grid.Column="6" Classes="ctrl"
                  Command="{Binding ToggleMuteCommand}">
            <Panel>
              <PathIcon Width="18" Height="18" Data="{StaticResource Icon.VolumeHigh}"
                        IsVisible="{Binding !IsMuted}" />
              <PathIcon Width="18" Height="18" Data="{StaticResource Icon.VolumeMuted}"
                        IsVisible="{Binding IsMuted}" />
            </Panel>
          </Button>

          <!-- Volume slider -->
          <Slider Grid.Column="7" Width="80" Minimum="0" Maximum="100"
                  Value="{Binding Volume}"
                  VerticalAlignment="Center"
                  Margin="2,0,6,0" />

          <!-- Screenshot -->
          <Button Grid.Column="8" Classes="ctrl"
                  Command="{Binding TakeScreenshotCommand}">
            <PathIcon Width="16" Height="16" Data="{StaticResource Icon.Screenshot}" />
          </Button>

          <!-- Fullscreen -->
          <Button Grid.Column="9" Classes="ctrl"
                  Click="FullscreenButton_OnClick">
            <PathIcon Name="FullscreenCtrlIcon" Width="18" Height="18"
                      Data="{StaticResource Icon.Fullscreen}" />
          </Button>

        </Grid>
      </StackPanel>
    </Border>

    <!-- ── Right-click context menu ──────────────────────────────────────── -->
    <Panel.ContextMenu>
      <ContextMenu Opening="RootContextMenu_Opening">

        <!-- Recent files (populated in code-behind) -->
        <MenuItem Name="RecentFilesMenuItem" Header="Open Recent" />
        <Separator />

        <MenuItem Header="Jump to Time..." Click="JumpToTime_Click" InputGesture="Ctrl+G" />
        <MenuItem Header="Load Subtitle..." Click="LoadSubtitle_Click" InputGesture="S" />
        <MenuItem Header="Screenshot" Command="{Binding TakeScreenshotCommand}" InputGesture="Alt+I" />
        <Separator />

        <!-- Speed sub-menu -->
        <MenuItem Header="Playback Speed">
          <MenuItem Header="0.25×" Click="Speed_Click" Tag="0.25" />
          <MenuItem Header="0.50×" Click="Speed_Click" Tag="0.5" />
          <MenuItem Header="0.75×" Click="Speed_Click" Tag="0.75" />
          <MenuItem Header="Normal (1×)" Click="Speed_Click" Tag="1.0" />
          <MenuItem Header="1.25×" Click="Speed_Click" Tag="1.25" />
          <MenuItem Header="1.50×" Click="Speed_Click" Tag="1.5" />
          <MenuItem Header="2×"    Click="Speed_Click" Tag="2.0" />
          <MenuItem Header="4×"    Click="Speed_Click" Tag="4.0" />
        </MenuItem>

        <!-- Audio tracks (populated in code-behind) -->
        <MenuItem Name="AudioTrackMenuItem" Header="Audio Track" />

        <!-- Subtitle tracks (populated in code-behind) -->
        <MenuItem Name="SubtitleTrackMenuItem" Header="Subtitle Track" />
        <Separator />

        <!-- Always on top (header updated in code-behind) -->
        <MenuItem Name="AlwaysOnTopMenuItem" Header="Always on Top" Click="AlwaysOnTop_Click" />

      </ContextMenu>
    </Panel.ContextMenu>

    </Panel>
</Window>
