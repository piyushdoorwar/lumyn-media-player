<Styles xmlns="https://github.com/avaloniaui">
  <Style Selector="Window">
    <Setter Property="FontFamily" Value="Cantarell, Ubuntu, Inter, Segoe UI, sans-serif" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="#3D3846" />
    <Setter Property="Foreground" Value="#F7F5F3" />
    <Setter Property="BorderBrush" Value="#5E5968" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Focusable" Value="False" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#4D4658" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="#2D2834" />
  </Style>

  <Style Selector="Button.accent">
    <Setter Property="Background" Value="#E95420" />
    <Setter Property="BorderBrush" Value="#F27835" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <Style Selector="Button.accent:pointerover">
    <Setter Property="Background" Value="#F15D22" />
  </Style>

  <Style Selector="Button.accent:pressed">
    <Setter Property="Background" Value="#C34113" />
  </Style>

  <Style Selector="Button.icon">
    <Setter Property="Width" Value="36" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="Height" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Slider">
    <Setter Property="Foreground" Value="#E95420" />
    <Setter Property="Focusable" Value="False" />
  </Style>

  <!-- Transparent icon buttons for the control bar overlay -->
  <Style Selector="Button.ctrl">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="#F7F5F3" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Width" Value="36" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="Height" Value="36" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Focusable" Value="False" />
  </Style>

  <Style Selector="Button.ctrl:pointerover">
    <Setter Property="Background" Value="#33FFFFFF" />
  </Style>

  <Style Selector="Button.ctrl:pressed">
    <Setter Property="Background" Value="#1AFFFFFF" />
  </Style>

  <Style Selector="PathIcon">
    <Setter Property="Foreground" Value="#F7F5F3" />
  </Style>

  <!-- Dim state for toggle buttons (loop, always-on-top) when inactive -->
  <Style Selector="Button.dim">
    <Setter Property="Opacity" Value="0.35" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="#F7F5F3" />
  </Style>
</Styles>
