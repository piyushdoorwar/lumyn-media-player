<Window
    x:Class="Lumyn.App.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Lumyn.App.Controls"
    xmlns:vm="using:Lumyn.App.ViewModels"
    xmlns:conv="using:Lumyn.App"
    Title="{Binding Title}"
    Width="980"
    Height="620"
    MinWidth="640"
    MinHeight="380"
    Background="#111111"
    Topmost="{Binding IsAlwaysOnTop}"
    CanResize="True"
    SystemDecorations="BorderOnly"
    ExtendClientAreaToDecorationsHint="False">

  <!--
    All layers stacked in a Panel. mpv renders video into an OpenGL surface
    at the bottom; Avalonia controls remain normal overlays above it.
  -->
  <Border Name="RootBorder" Background="#111111" BorderThickness="2">
  <Grid RowDefinitions="Auto,*">

    <!-- ── Top bar (own row – no mpv surface behind it) ─────────────────── -->
    <Border
        Name="TopBar"
        Grid.Row="0"
        Background="#141414"
        IsHitTestVisible="True"
        MinHeight="38">
      <Grid ColumnDefinitions="Auto,*,Auto">

        <!-- Left: logo + open + subtitles -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0">
          <Image Width="18" Height="18" Margin="10,0,6,0"
                 Source="{StaticResource Icon.LumynMark}"
                 IsHitTestVisible="False" />
          <Button Classes="icon ctrl" Name="OpenButton"
                  Click="OpenButton_OnClick">
            <PathIcon Width="15" Height="15" Data="{StaticResource Icon.Open}" />
          </Button>
          <Button Classes="icon ctrl" Name="LoadSubtitleButton"
                  Click="LoadSubtitleButton_OnClick">
            <PathIcon Width="15" Height="15" Data="{StaticResource Icon.Subtitle}" />
          </Button>
        </StackPanel>

        <!-- Centre: drag region + title -->
        <Border Grid.Column="1"
                Background="Transparent"
                PointerPressed="TitleBar_PointerPressed">
          <TextBlock Text="{Binding Title}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     FontSize="12" Foreground="#DEDAD5"
                     TextTrimming="CharacterEllipsis"
                     IsHitTestVisible="False" />
        </Border>

        <!-- Right: info | pin | window chrome -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0">
          <Button Classes="icon ctrl" Name="AboutButton"
                  Click="AboutButton_Click">
            <PathIcon Width="13" Height="13" Data="{StaticResource Icon.Info}" />
          </Button>
          <Button Classes="icon ctrl" Name="SettingsButton"
                  Click="SettingsButton_Click">
            <PathIcon Width="14" Height="14" Data="{StaticResource Icon.Settings}" />
          </Button>
          <Button Classes="icon ctrl" Name="AlwaysOnTopButton"
                  Classes.dim="{Binding !IsAlwaysOnTop}"
                  IsVisible="{Binding ShowPinButton}"
                  Command="{Binding ToggleAlwaysOnTopCommand}">
            <PathIcon Width="13" Height="13" Data="{StaticResource Icon.AlwaysOnTop}" />
          </Button>
          <!-- Divider -->
          <Border Width="1" Margin="4,9" Background="#383838" />
          <!-- Window chrome -->
          <Button Classes="wchrome" Name="MinimizeButton"
                  Click="MinimizeButton_Click">
            <PathIcon Width="11" Height="11" Data="{StaticResource Icon.WindowMinimize}" />
          </Button>
          <Button Classes="wchrome" Name="MaximizeButton"
                  Click="MaximizeButton_Click">
            <PathIcon Name="MaximizeIcon" Width="11" Height="11"
                      Data="{StaticResource Icon.WindowMaximize}" />
          </Button>
          <Button Classes="wchrome close" Name="CloseButton"
                  Click="CloseButton_Click">
            <PathIcon Width="11" Height="11" Data="{StaticResource Icon.WindowClose}" />
          </Button>
        </StackPanel>

      </Grid>
    </Border>

    <!-- ── Video area (mpv + overlays + bottom bar) ──────────────────────── -->
    <Grid Name="Root" Grid.Row="1" Background="#111111" DragDrop.AllowDrop="True">
    <Panel Name="VideoPanel" Background="#111111" DragDrop.AllowDrop="True">

    <!-- ── Video frame (mpv OpenGL render API) ──────────────────────────── -->
    <controls:MpvVideoSurface Name="VideoSurface"
           Playback="{Binding Playback}"
           HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
           IsHitTestVisible="False" />

    <!-- ── Transparent click / double-click surface ──────────────────────── -->
    <Border Name="VideoClickLayer" Background="Transparent"
            DragDrop.AllowDrop="True"
            PointerPressed="VideoClickLayer_OnPointerPressed" />

    <!-- ── Subtitle overlay (Avalonia-rendered) ──────────────────────────── -->
    <Border VerticalAlignment="Bottom"
            HorizontalAlignment="Stretch"
            Margin="24,0,24,94"
            IsHitTestVisible="False"
            IsVisible="{Binding CurrentSubtitleText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="{Binding CurrentSubtitleText}"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 FontSize="{Binding SubtitleFontSizeValue}"
                 FontFamily="{Binding SubtitleFontFamily}"
                 FontWeight="SemiBold"
                 Foreground="{Binding SubtitleForeground}"
                 TextWrapping="Wrap"
                 MaxWidth="900">
        <TextBlock.Effect>
          <DropShadowEffect BlurRadius="4" OffsetX="1" OffsetY="1" Color="Black" Opacity="0.9" />
        </TextBlock.Effect>
      </TextBlock>
    </Border>

    <!-- ── Audio-only mode panel ─────────────────────────────────────────── -->
    <Grid Name="AudioModePanel"
          IsVisible="{Binding IsAudioMode}"
          Background="#111111"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">

      <!-- Ambient blurred cover-art backdrop (subtle, like YT/Apple Music).
           Blur of the cover supplies the colour; the scrim keeps it muted. -->
      <Panel ClipToBounds="True"
             IsHitTestVisible="False"
             IsVisible="{Binding HasCoverArt}">
        <Image Source="{Binding CoverArtBitmap}"
               Stretch="UniformToFill"
               Opacity="0.55">
          <Image.Effect>
            <BlurEffect Radius="110" />
          </Image.Effect>
        </Image>
        <Border Background="#111111" Opacity="0.6" />
      </Panel>

      <!-- YouTube-Music two-pane: hero on the left (~60%), queue on the right (~40%).
           The queue column collapses to 0 for a single file so the hero stays centred. -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="7*" />
          <ColumnDefinition Width="{Binding HasPlaylist, Converter={x:Static conv:Converters.QueueColumnWidth}}" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: cover, song info, waveform below the cover -->
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="18" Margin="24,0">

          <Border Width="216" Height="216"
                  CornerRadius="16"
                  ClipToBounds="True"
                  Background="#1E1E1E"
                  BorderBrush="#303030"
                  BorderThickness="1"
                  HorizontalAlignment="Center">
            <Panel>
              <Image Source="{Binding CoverArtBitmap}"
                     Stretch="UniformToFill"
                     IsVisible="{Binding HasCoverArt}" />
              <PathIcon Width="72" Height="72"
                        Data="{StaticResource Icon.MusicNote}"
                        Foreground="#353535"
                        IsVisible="{Binding !HasCoverArt}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
            </Panel>
          </Border>

          <StackPanel Spacing="4" HorizontalAlignment="Center">
            <TextBlock Text="{Binding TrackTitle}"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="#F2EFEC"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextTrimming="CharacterEllipsis" MaxWidth="360"
                       IsVisible="{Binding TrackTitle,
                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <TextBlock Text="{Binding TrackArtistAlbum}"
                       FontSize="14"
                       Foreground="#7A7675"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextTrimming="CharacterEllipsis" MaxWidth="360"
                       IsVisible="{Binding TrackArtistAlbum,
                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          </StackPanel>

          <!-- Music-reactive equalizer bars, sized to match the cover -->
          <controls:AudioBars Name="AudioVisualizer"
                              Width="216" Height="60"
                              HorizontalAlignment="Center"
                              IsActive="{Binding IsPlaying}" />
        </StackPanel>

        <!-- RIGHT: the queue ("Up next"), only when there are 2+ tracks -->
        <Border Grid.Column="1"
                IsVisible="{Binding HasPlaylist}"
                Background="#0A0A0A"
                BorderBrush="#1E1E1E"
                BorderThickness="1,0,0,0">
          <Grid RowDefinitions="48,*">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="18,0,16,0">
              <TextBlock Grid.Column="0" Text="Up next"
                         VerticalAlignment="Center"
                         FontSize="13" FontWeight="SemiBold" Foreground="#C8C3C2" />
              <TextBlock Grid.Column="1" Text="{Binding PlaylistPositionLabel}"
                         VerticalAlignment="Center"
                         FontSize="11" Foreground="#5A5755" />
            </Grid>

            <!-- Queue rows -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
              <ItemsControl Name="AudioQueueItemsControl"
                            ItemsSource="{Binding PlaylistItems}"
                            DragDrop.AllowDrop="True">

                <ItemsControl.Styles>
                  <Style Selector="Border.aq-row:pointerover">
                    <Setter Property="Background" Value="#0BFFFFFF" />
                  </Style>
                  <Style Selector="Border.aq-row.active">
                    <Setter Property="Background" Value="#1649B35C" />
                  </Style>
                  <Style Selector="Border.aq-row:pointerover PathIcon.drag-icon">
                    <Setter Property="Foreground" Value="#4A4846" />
                  </Style>
                  <Style Selector="Border.aq-row:pointerover Button.remove-btn">
                    <Setter Property="Opacity" Value="0.8" />
                  </Style>
                  <Style Selector="TextBlock.aq-title.active">
                    <Setter Property="Foreground" Value="#9FD4AC" />
                  </Style>
                </ItemsControl.Styles>

                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="aq-row"
                            Classes.active="{Binding IsCurrent}"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="4,4" Margin="6,1">
                      <Grid ColumnDefinitions="18,44,*,Auto,28">

                        <!-- Drag handle -->
                        <Border Grid.Column="0"
                                Background="Transparent"
                                Cursor="SizeAll"
                                PointerPressed="PlaylistDragHandle_PointerPressed">
                          <PathIcon Classes="drag-icon"
                                    Width="9" Height="9"
                                    Data="{StaticResource Icon.DragHandle}"
                                    Foreground="#2A2826"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </Border>

                        <!-- Cover thumbnail -->
                        <Border Grid.Column="1" Width="38" Height="38"
                                CornerRadius="5" ClipToBounds="True"
                                Background="#1A1A1A" VerticalAlignment="Center">
                          <Panel>
                            <Image Source="{Binding CoverBitmap}"
                                   Stretch="UniformToFill"
                                   IsVisible="{Binding HasCover}" />
                            <PathIcon Width="15" Height="15"
                                      Data="{StaticResource Icon.MusicNote}"
                                      Foreground="#333333"
                                      IsVisible="{Binding !HasCover}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                          </Panel>
                        </Border>

                        <!-- Title + artist (click to play) -->
                        <Button Grid.Column="2"
                                Command="{Binding $parent[Window].DataContext.OpenPlaylistItemCommand}"
                                CommandParameter="{Binding Index}"
                                Padding="10,0,6,0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0">
                          <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Classes="aq-title"
                                       Classes.active="{Binding IsCurrent}"
                                       Text="{Binding TitleLabel}"
                                       FontSize="13" Foreground="#B7B2AE"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding ArtistLabel}"
                                       FontSize="11" Foreground="#6A6560"
                                       TextTrimming="CharacterEllipsis"
                                       IsVisible="{Binding HasArtist}" />
                          </StackPanel>
                        </Button>

                        <!-- Duration -->
                        <TextBlock Grid.Column="3"
                                   Text="{Binding DurationLabel}"
                                   VerticalAlignment="Center"
                                   Margin="6,0"
                                   FontSize="11" Foreground="#5A5755" />

                        <!-- Remove (dim at rest, brighter on row hover) -->
                        <Button Grid.Column="4" Classes="ctrl remove-btn"
                                Command="{Binding $parent[Window].DataContext.RemovePlaylistItemCommand}"
                                CommandParameter="{Binding Index}"
                                Width="28" Height="28" MinWidth="28" MinHeight="28"
                                Opacity="0.0">
                          <PathIcon Width="9" Height="9"
                                    Data="{StaticResource Icon.WindowClose}"
                                    Foreground="#6A6560" />
                        </Button>

                        <!-- Right-click context menu -->
                        <Grid.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="▶  Play" Click="PlaylistCtx_Play" />
                            <Separator />
                            <MenuItem Header="Remove from queue" Click="PlaylistCtx_Remove" />
                            <Separator />
                            <MenuItem Header="Add file to queue…" Click="PlaylistCtx_AddFile" />
                            <MenuItem Header="Add folder to queue…" Click="PlaylistCtx_AddFolder" />
                          </ContextMenu>
                        </Grid.ContextMenu>

                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- ── Start / Empty screen ───────────────────────────────────────────── -->
    <Grid IsVisible="{Binding !HasMedia}"
          IsHitTestVisible="{Binding !HasMedia}"
          Background="#111111">

      <!-- No recent files: simple logo placeholder -->
      <StackPanel
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Spacing="12"
          IsVisible="{Binding !HasRecentFiles}">
        <Image Width="120" Height="120" Opacity="0.85" Source="{StaticResource Icon.LumynLogo}" />
        <TextBlock Text="Lumyn" FontSize="28" FontWeight="SemiBold"
                   Foreground="#F7F5F3" HorizontalAlignment="Center" />
        <TextBlock Text="Drop a file here, press O to open, or right-click"
                   FontSize="13" Foreground="#807C79" HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Has recent files: recently played grid -->
      <Grid IsVisible="{Binding HasRecentFiles}"
            RowDefinitions="Auto,*"
            Margin="24,18,24,12">

        <controls:FlowWatermark Grid.RowSpan="2"
                                Margin="-24,-18,-24,-12"
                                Opacity="0.95" />

        <!-- Heading -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,18">
          <Image Width="22" Height="22" Source="{StaticResource Icon.LumynMark}" Opacity="0.7" />
          <TextBlock Text="Recently Played"
                     FontSize="16" FontWeight="SemiBold"
                     Foreground="#E0DCD8" VerticalAlignment="Center" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding RecentFileItems}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Panel Width="200" Height="120" Margin="0,0,10,10">

                  <Button Click="RecentItem_Click"
                          Tag="{Binding FilePath}"
                          Width="200" Height="120" Margin="0" Padding="0"
                          Background="#1A1A1A"
                          BorderBrush="#2A2A2A" BorderThickness="1"
                          CornerRadius="6"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          ClipToBounds="True">
                    <Panel>
                      <!-- Thumbnail (full-bleed, video only) -->
                      <Image Source="{Binding ThumbnailBitmap}"
                             Stretch="UniformToFill"
                             IsVisible="{Binding HasThumbnail}" />
                      <!-- Gradient overlay for readability -->
                      <Border>
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                            <GradientStop Color="#00000000" Offset="0.2" />
                            <GradientStop Color="#CC000000" Offset="1" />
                          </LinearGradientBrush>
                        </Border.Background>
                      </Border>
                      <!-- Progress % badge top-left -->
                      <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                              Margin="6,6,0,0" Padding="4,2"
                              Background="#CC000000" CornerRadius="3"
                              IsVisible="{Binding HasResume}">
                        <TextBlock Text="{Binding ProgressLabel}"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="#3A9B4B" />
                      </Border>
                      <!-- Text at bottom -->
                      <StackPanel VerticalAlignment="Bottom" Margin="10,0,28,8" Spacing="2">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#F0ECE8"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="2" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ResumeLabel}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#3A9B4B"
                                   IsVisible="{Binding HasResume}" />
                      </StackPanel>
                      <!-- Progress bar pinned to bottom edge -->
                      <controls:MiniProgressBar
                          VerticalAlignment="Bottom"
                          Height="3"
                          Minimum="0" Maximum="100"
                          Value="{Binding ProgressPct}"
                          IsVisible="{Binding HasResume}" />
                    </Panel>
                  </Button>

                  <!-- Remove button -->
                  <Button Classes="ctrl remove-btn"
                          Command="{Binding $parent[Window].DataContext.RemoveRecentFileCommand}"
                          CommandParameter="{Binding FilePath}"
                          Width="20" Height="20" MinWidth="20" MinHeight="20"
                          HorizontalAlignment="Right" VerticalAlignment="Top"
                          Margin="0,4,4,0" Opacity="0.5">
                    <PathIcon Width="7" Height="7"
                              Data="{StaticResource Icon.WindowClose}"
                              Foreground="#AAAAAA" />
                  </Button>

                </Panel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

      </Grid>

    </Grid>

    <!-- ── Error banner ──────────────────────────────────────────────────── -->
    <Border
        VerticalAlignment="Top"
        Margin="0,48,0,0"
        IsVisible="{Binding HasError}"
        Padding="16,8"
        Background="#CC77216F"
        IsHitTestVisible="False">
      <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFFFFF"
                 TextWrapping="Wrap" HorizontalAlignment="Center" />
    </Border>

    <!-- ── OSD toast ────────────────────────────────────────────────────── -->
    <Border
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Margin="16,52,16,0"
        Padding="10,7,14,7"
        MaxWidth="480"
        CornerRadius="6"
        Background="#99101214"
        BorderBrush="#1AFFFFFF"
        BorderThickness="1"
        IsVisible="{Binding HasOsd}"
        IsHitTestVisible="False">
      <Border.Effect>
        <DropShadowEffect BlurRadius="8" OffsetX="0" OffsetY="3" Color="#000000" Opacity="0.25" />
      </Border.Effect>
      <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
        <PathIcon Grid.Column="0"
                  Width="11" Height="11"
                  Data="{StaticResource Icon.Info}"
                  Foreground="#5A9B6A"
                  VerticalAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Text="{Binding OsdMessage}"
                   Margin="8,0,0,0"
                   FontSize="12"
                   Foreground="#C8C4C0"
                   TextWrapping="Wrap"
                   TextTrimming="CharacterEllipsis"
                   MaxLines="2"
                   VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- ── Cast status pill ──────────────────────────────────────────────── -->
    <Border
        Name="CastStatusBar"
        VerticalAlignment="Bottom"
        Margin="14,0,14,88"
        Padding="10,7"
        CornerRadius="6"
        Background="#E51B1B1B"
        BorderBrush="#443A9B4B"
        BorderThickness="1"
        IsVisible="{Binding IsCasting}"
        HorizontalAlignment="Center">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <PathIcon Width="15" Height="15" Data="{StaticResource Icon.Cast}" Foreground="#49B35C" />
        <TextBlock Text="{Binding CastStatusText}" Foreground="#F4F0EC" FontSize="12"
                   VerticalAlignment="Center" />
        <Button Classes="ctrl" Command="{Binding ToggleCastPlaybackCommand}">
          <Panel>
            <PathIcon Width="14" Height="14" Data="{StaticResource Icon.Play}"
                      IsVisible="{Binding !IsCastPlaying}" />
            <PathIcon Width="14" Height="14" Data="{StaticResource Icon.Pause}"
                      IsVisible="{Binding IsCastPlaying}" />
          </Panel>
        </Button>
        <Button Classes="ctrl" Command="{Binding StopCastingCommand}">
          <PathIcon Width="13" Height="13" Data="{StaticResource Icon.Stop}" />
        </Button>
      </StackPanel>
    </Border>

    <Border
        Name="ControlBar"
        VerticalAlignment="Bottom"
        Padding="12,0,12,10"
        IsVisible="{Binding ControlsVisible}"
        IsHitTestVisible="{Binding ControlsVisible}">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#00000000" Offset="0" />
          <GradientStop Color="#D5000000" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
      <StackPanel Spacing="0">

        <!-- Seek row -->
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="10"
              Margin="28,0,28,4"
              MinHeight="24">
          <TextBlock Grid.Column="0"
                     Text="{Binding PositionText}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Left"
                     FontSize="12"
                     Foreground="#C8C3C2"
                     MinWidth="50" />

          <controls:SeekBar
              Grid.Column="1"
              Name="SeekSlider"
              Minimum="0"
              Maximum="1000"
              Value="{Binding SeekValue}"
              VerticalAlignment="Center"
              SeekCommitted="SeekSlider_OnSeekCommitted" />

          <TextBlock Grid.Column="2"
                     Text="{Binding DurationText}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Right"
                     TextAlignment="Right"
                     FontSize="12"
                     Foreground="#C8C3C2"
                     Cursor="Hand"
                     PointerPressed="DurationText_OnPointerPressed"
                     MinWidth="50" />
        </Grid>

        <!-- Transport row -->
        <Grid ColumnDefinitions="*,Auto,*"
              Margin="28,0,28,0"
              MinHeight="42">

          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      Spacing="2"
                      HorizontalAlignment="Left">
            <Button Classes="ctrl"
                    Command="{Binding StopCommand}">
              <PathIcon Width="14" Height="14" Data="{StaticResource Icon.Stop}" />
            </Button>

            <Button Classes="ctrl"
                    Classes.dim="{Binding !IsLooping}"
                    IsVisible="{Binding ShowLoopButton}"
                    Command="{Binding ToggleLoopCommand}">
              <PathIcon Width="16" Height="16" Data="{StaticResource Icon.Loop}" />
            </Button>

            <Button Classes="ctrl"
                    Width="54"
                    IsVisible="{Binding ShowSeekStepButton}"
                    Command="{Binding CycleSeekStepCommand}">
              <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                <PathIcon Width="13" Height="13" Data="{StaticResource Icon.SeekForward}" />
                <TextBlock Text="{Binding SeekStepLabel}" FontSize="10"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Classes="ctrl" Name="BookmarksButton"
                    IsVisible="{Binding ShowMarkersButton}"
                    Click="BookmarksButton_Click">
              <PathIcon Width="15" Height="15" Data="{StaticResource Icon.BookmarkOutline}" />
            </Button>

            <Button Classes="ctrl"
                    IsVisible="{Binding ShowScreenshotButton}"
                    Command="{Binding TakeScreenshotCommand}">
              <PathIcon Width="16" Height="16" Data="{StaticResource Icon.Screenshot}" />
            </Button>
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="5"
                      HorizontalAlignment="Center">

            <Button Classes="ctrl"
                    Classes.dim="{Binding !HasPreviousTrack}"
                    Command="{Binding PreviousTrackCommand}">
              <PathIcon Width="16" Height="16" Data="{StaticResource Icon.SkipPrevious}" />
            </Button>

            <Button Classes="ctrl"
                    Command="{Binding SeekBackwardCommand}">
              <PathIcon Width="16" Height="16" Data="{StaticResource Icon.SeekBack}" />
            </Button>

            <Button Classes="ctrl play-primary"
                    Command="{Binding TogglePlayPauseCommand}">
              <Panel>
                <PathIcon Width="20" Height="20" Data="{StaticResource Icon.Play}"
                          Margin="3,0,0,0"
                          IsVisible="{Binding !IsPlaying}" />
                <PathIcon Width="20" Height="20" Data="{StaticResource Icon.Pause}"
                          IsVisible="{Binding IsPlaying}" />
              </Panel>
            </Button>

            <Button Classes="ctrl"
                    Command="{Binding SeekForwardCommand}">
              <PathIcon Width="16" Height="16" Data="{StaticResource Icon.SeekForward}" />
            </Button>

            <Button Classes="ctrl"
                    Classes.dim="{Binding !HasNextTrack}"
                    Command="{Binding NextTrackCommand}">
              <PathIcon Width="16" Height="16" Data="{StaticResource Icon.SkipNext}" />
            </Button>
          </StackPanel>

          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      Spacing="2"
                      HorizontalAlignment="Right">
            <Button Classes="ctrl"
                    Command="{Binding ResetSpeedCommand}"
                    IsVisible="{Binding !IsNormalSpeed}">
              <Border Background="#2A2A2A" CornerRadius="4" Padding="6,2">
                <TextBlock Text="{Binding SpeedLabel}" FontSize="11"
                           Foreground="#E8E4E0" FontWeight="Medium"
                           VerticalAlignment="Center" />
              </Border>
            </Button>

            <Button Classes="ctrl" Name="CastButton"
                    Classes.dim="{Binding !IsCasting}"
                    IsVisible="{Binding ShowCastButton}"
                    Click="CastButton_Click">
              <PathIcon Width="16" Height="16" Data="{StaticResource Icon.Cast}" />
            </Button>

            <StackPanel Orientation="Horizontal"
                        Spacing="3"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0">
              <Button Classes="ctrl"
                      Width="30"
                      MinWidth="30"
                      Command="{Binding ToggleMuteCommand}">
                <Panel>
                  <PathIcon Width="17" Height="17" Data="{StaticResource Icon.VolumeHigh}"
                            IsVisible="{Binding !IsMuted}" />
                  <PathIcon Width="17" Height="17" Data="{StaticResource Icon.VolumeMuted}"
                            IsVisible="{Binding IsMuted}" />
                </Panel>
              </Button>

              <controls:VolumeSlider Width="96" Minimum="0" Maximum="150"
                                     Value="{Binding Volume}"
                                     VerticalAlignment="Center" />
            </StackPanel>

            <Button Classes="ctrl"
                    Click="FullscreenButton_OnClick">
              <PathIcon Name="FullscreenCtrlIcon" Width="18" Height="18"
                        Data="{StaticResource Icon.Fullscreen}" />
            </Button>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <!-- ── Seek thumbnail preview ────────────────────────────────────────── -->
    <Border Name="SeekThumbnailPopup"
            IsVisible="False"
            IsHitTestVisible="False"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Width="164"
            CornerRadius="5"
            Background="#F0111111"
            BorderBrush="#22FFFFFF"
            BorderThickness="1">
      <Border.Effect>
        <DropShadowEffect BlurRadius="14" OffsetX="0" OffsetY="-4" Color="Black" Opacity="0.6" />
      </Border.Effect>
      <StackPanel Margin="4,4,4,5">
        <Border Width="156" Height="88"
                CornerRadius="3"
                ClipToBounds="True"
                Background="#0E0E0E">
          <Image Name="SeekThumbnailImage"
                 Width="156" Height="88"
                 Stretch="Uniform" />
        </Border>
        <TextBlock Name="SeekThumbnailTimeText"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="#C8C3C2"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- ── Right-click context menu ──────────────────────────────────────── -->
    <Panel.ContextMenu>
      <ContextMenu Name="RootContextMenu" Opening="RootContextMenu_Opening">

        <!-- Recent files (populated in code-behind) -->
        <MenuItem Name="RecentFilesMenuItem" Header="Open Recent" />
        <Separator />

        <MenuItem Header="Open Folder..." Click="OpenFolder_Click" />
        <MenuItem Header="Add to Queue..." Click="AddToQueue_Click" />
        <Separator />

        <MenuItem Header="Jump to Time..." Click="JumpToTime_Click" InputGesture="Ctrl+G" />
        <MenuItem Header="Load Subtitle..." Click="LoadSubtitle_Click" InputGesture="S" />
        <MenuItem Header="Video Adjustments..." Click="VideoAdjustments_Click" />
        <MenuItem Header="Cast..." Click="Cast_Click" />
        <MenuItem Header="Keyboard Shortcuts" Click="KeyboardShortcuts_Click" />
        <MenuItem Header="Screenshot" Command="{Binding TakeScreenshotCommand}" InputGesture="Alt+I" />
        <MenuItem Header="Markers…" Click="Bookmarks_Click" InputGesture="B" />
        <Separator />

        <!-- Speed sub-menu -->
        <MenuItem Header="Playback Speed">
          <MenuItem Header="0.25×" Click="Speed_Click" Tag="0.25" />
          <MenuItem Header="0.50×" Click="Speed_Click" Tag="0.5" />
          <MenuItem Header="0.75×" Click="Speed_Click" Tag="0.75" />
          <MenuItem Header="Normal (1×)" Click="Speed_Click" Tag="1.0" />
          <MenuItem Header="1.25×" Click="Speed_Click" Tag="1.25" />
          <MenuItem Header="1.50×" Click="Speed_Click" Tag="1.5" />
          <MenuItem Header="2×"    Click="Speed_Click" Tag="2.0" />
          <MenuItem Header="4×"    Click="Speed_Click" Tag="4.0" />
        </MenuItem>

        <!-- Audio tracks (populated in code-behind) -->
        <MenuItem Name="AudioTrackMenuItem" Header="Audio Track" />

        <!-- Subtitle tracks (populated in code-behind) -->
        <MenuItem Name="SubtitleTrackMenuItem" Header="Subtitle Track" />
        <Separator />

        <!-- Always on top (header updated in code-behind) -->
        <MenuItem Name="AlwaysOnTopMenuItem" Header="Always on Top" Click="AlwaysOnTop_Click" />
        <Separator />
        <MenuItem Header="About Lumyn…" Click="About_Click" />

      </ContextMenu>
    </Panel.ContextMenu>

    </Panel>

    </Grid>
  </Grid>
  </Border>
</Window>
