<Styles xmlns="https://github.com/avaloniaui">
  <Style Selector="Window">
    <Setter Property="FontFamily" Value="Cantarell, Ubuntu, Inter, Segoe UI, sans-serif" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="#3D3846" />
    <Setter Property="Foreground" Value="#F7F5F3" />
    <Setter Property="BorderBrush" Value="#5E5968" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Transitions">
      <Transitions />
    </Setter>
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#4D4658" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="#2D2834" />
  </Style>

  <Style Selector="Button.accent">
    <Setter Property="Background" Value="#3A9B4B" />
    <Setter Property="BorderBrush" Value="#48B35A" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <Style Selector="Button.accent:pointerover">
    <Setter Property="Background" Value="#43AD56" />
  </Style>

  <Style Selector="Button.accent:pressed">
    <Setter Property="Background" Value="#2F7D3D" />
  </Style>

  <Style Selector="Button.icon">
    <Setter Property="Width" Value="36" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="Height" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.icon:pointerover">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.downloadIcon">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Width" Value="34" />
    <Setter Property="MinWidth" Value="34" />
    <Setter Property="Height" Value="34" />
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="Button.downloadIcon:pointerover">
    <Setter Property="Background" Value="#223D3846" />
  </Style>

  <Style Selector="Button.downloadIcon:pressed">
    <Setter Property="Background" Value="#334D4658" />
  </Style>

  <Style Selector="Slider">
    <Setter Property="Foreground" Value="#3A9B4B" />
    <Setter Property="Focusable" Value="False" />
  </Style>

  <!-- Transparent icon buttons for the control bar overlay -->
  <Style Selector="Button.ctrl">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="#F7F5F3" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Width" Value="36" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="Height" Value="36" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Focusable" Value="False" />
  </Style>

  <Style Selector="Button.ctrl:pointerover">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.ctrl:pressed">
    <Setter Property="Background" Value="#1AFFFFFF" />
  </Style>

  <Style Selector="Button.play-primary">
    <Setter Property="Background" Value="#3A9B4B" />
    <Setter Property="CornerRadius" Value="22" />
    <Setter Property="Width" Value="44" />
    <Setter Property="MinWidth" Value="44" />
    <Setter Property="Height" Value="44" />
    <Setter Property="MinHeight" Value="44" />
  </Style>

  <Style Selector="Button.play-primary:pointerover">
    <Setter Property="Background" Value="#43AD56" />
  </Style>

  <Style Selector="Button.play-primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#43AD56" />
  </Style>

  <Style Selector="Button.play-primary:pressed">
    <Setter Property="Background" Value="#2F7D3D" />
  </Style>

  <Style Selector="Button.play-primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#2F7D3D" />
  </Style>

  <Style Selector="PathIcon">
    <Setter Property="Foreground" Value="#F7F5F3" />
  </Style>

  <!-- Dim state for toggle buttons (loop, always-on-top) when inactive -->
  <Style Selector="Button.dim">
    <Setter Property="Opacity" Value="0.35" />
  </Style>

  <!-- Window chrome buttons (minimize / maximize / close) -->
  <Style Selector="Button.wchrome">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="#AAAAAA" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Width" Value="42" />
    <Setter Property="MinWidth" Value="42" />
    <Setter Property="Height" Value="38" />
    <Setter Property="MinHeight" Value="38" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Focusable" Value="False" />
  </Style>

  <Style Selector="Button.wchrome:pointerover">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.wchrome:pressed">
    <Setter Property="Background" Value="#333333" />
  </Style>

  <Style Selector="Button.wchrome.close:pointerover">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.wchrome.close:pressed">
    <Setter Property="Background" Value="#A01E12" />
  </Style>

  <!-- Link-style text buttons (About dialog footer) -->
  <Style Selector="Button.link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="#3A9B4B" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <Style Selector="Button.link:pointerover">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#48B35A" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="#F7F5F3" />
  </Style>

  <!-- ── Scrollbar ──────────────────────────────────────────────────────── -->

  <!-- Thin track -->
  <Style Selector="ScrollBar:vertical">
    <Setter Property="Width" Value="6" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Margin" Value="0,2,1,2" />
  </Style>
  <Style Selector="ScrollBar:horizontal">
    <Setter Property="Height" Value="6" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Margin" Value="2,0,2,1" />
  </Style>

  <!-- Hide line buttons (up/down arrows) -->
  <Style Selector="ScrollBar /template/ RepeatButton">
    <Setter Property="IsVisible" Value="False" />
    <Setter Property="Height" Value="0" />
    <Setter Property="Width" Value="0" />
  </Style>

  <!-- Green thumb — opacity drives hover/press since Fluent overrides Background internally -->
  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="#3A9B4B" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="MinHeight" Value="20" />
    <Setter Property="MinWidth" Value="4" />
    <Setter Property="Opacity" Value="0.35" />
  </Style>

  <Style Selector="ScrollBar /template/ Thumb:pointerover">
    <Setter Property="Opacity" Value="0.75" />
  </Style>

  <Style Selector="ScrollBar /template/ Thumb:pressed">
    <Setter Property="Opacity" Value="1.0" />
  </Style>

  <!-- Track area behind the thumb -->
  <Style Selector="ScrollBar /template/ Border#PART_TrackBorder">
    <Setter Property="Background" Value="#0DFFFFFF" />
    <Setter Property="CornerRadius" Value="3" />
  </Style>
</Styles>
