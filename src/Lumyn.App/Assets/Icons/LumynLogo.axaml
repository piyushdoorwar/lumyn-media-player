<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Lumyn logo as a DrawingImage — reusable at any size via <Image>.
    Coordinate space: 256 × 256.
    Stroke paths use a green Pen; the play-triangle uses a softened light fill.
  -->
  <DrawingImage x:Key="Icon.LumynLogo">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <!-- Signal lines -->
        <GeometryDrawing Geometry="M22 71.5L135 19">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 103.5L234 5">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 135.5L234 37">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 167.5L234 69">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <!-- TV body -->
        <GeometryDrawing Geometry="M96 118V181H62L67 207H189L194 181H159V130">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" LineJoin="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <!-- TV stand legs -->
        <GeometryDrawing Geometry="M71 217L184 197">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="12" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M75 239L176 221">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="12" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <!-- Play triangle -->
        <GeometryDrawing
            Brush="#D8D4CF"
            Geometry="M112 150C112 147.7 114.5 146.3 116.5 147.5L142.5 163.2C145.5 165 145.5 170 142.5 171.8L116.5 187.5C114.5 188.7 112 187.3 112 185V150Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Transmux clapperboard mark, based on the Transmux website SVG. -->
  <DrawingImage x:Key="Icon.TransmuxLogo">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#3A6E9B" Geometry="M32 102H222V234H32Z" />
        <GeometryDrawing Geometry="M32 102H222V234H32Z">
          <GeometryDrawing.Pen><Pen Brush="#111111" Thickness="12" LineJoin="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Brush="#DEDAD5" Geometry="M30 92H224V124H30Z" />
        <GeometryDrawing Geometry="M30 92H224V124H30Z">
          <GeometryDrawing.Pen><Pen Brush="#111111" Thickness="10" LineJoin="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Brush="#DEDAD5" Geometry="M28 49L216 21L222 52L31 80Z" />
        <GeometryDrawing Geometry="M28 49L216 21L222 52L31 80Z">
          <GeometryDrawing.Pen><Pen Brush="#111111" Thickness="10" LineJoin="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Brush="#111111" Geometry="M28 49L67 78L31 83Z" />
        <GeometryDrawing Brush="#111111" Geometry="M66 39L111 73L148 67L101 33Z" />
        <GeometryDrawing Brush="#111111" Geometry="M143 28L188 62L222 56L180 22Z" />
        <GeometryDrawing Brush="#111111" Geometry="M29 124L67 88L108 88L71 124Z" />
        <GeometryDrawing Brush="#111111" Geometry="M149 124L188 88H224L187 124Z" />
        <GeometryDrawing Brush="#DEDAD5" Geometry="M68 160H186V214H68Z" />
        <GeometryDrawing Geometry="M68 160H186V214H68Z">
          <GeometryDrawing.Pen><Pen Brush="#111111" Thickness="8" LineJoin="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M84 178H166">
          <GeometryDrawing.Pen><Pen Brush="#111111" Thickness="8" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M84 195H130">
          <GeometryDrawing.Pen><Pen Brush="#111111" Thickness="8" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!--
    Compact mark for small sizes (top bar, taskbar) — no stand legs.
  -->
  <DrawingImage x:Key="Icon.LumynMark">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Geometry="M22 71.5L135 19">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 103.5L234 5">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 135.5L234 37">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M22 167.5L234 69">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Geometry="M96 118V181H62L67 207H189L194 181H159V130">
          <GeometryDrawing.Pen><Pen Brush="#3A9B4B" Thickness="18" LineCap="Round" LineJoin="Round" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing
            Brush="#D8D4CF"
            Geometry="M112 150C112 147.7 114.5 146.3 116.5 147.5L142.5 163.2C145.5 165 145.5 170 142.5 171.8L116.5 187.5C114.5 188.7 112 187.3 112 185V150Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

</ResourceDictionary>
