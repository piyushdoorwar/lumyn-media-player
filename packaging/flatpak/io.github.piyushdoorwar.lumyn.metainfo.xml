<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.piyushdoorwar.lumyn</id>

  <name>Lumyn</name>
  <summary>A clean desktop media player</summary>

  <description>
    <p>
      Lumyn is a quiet, fast local video and audio player with a focused interface,
      mpv-powered playback, subtitle tools, and the controls you expect close at hand.
    </p>
    <ul>
      <li>Native playback through mpv — hardware-decoded, smooth, and format-flexible</li>
      <li>Subtitle file loading, embedded track selection, delay adjustment, and appearance settings</li>
      <li>Speed control, looping, screenshots, and audio track switching</li>
      <li>Playlist and queue support with drag-to-reorder and right-click context menu</li>
      <li>Audio-only mode with cover art display and folder-scanning queue</li>
      <li>Compact custom title bar with keyboard-driven workflow</li>
    </ul>
  </description>

  <url type="homepage">https://github.com/piyushdoorwar/lumyn-media-player</url>
